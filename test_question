#include<bits/stdc++.h>
using namespace std;
int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
	cout.tie(nullptr);
    int T;
    cin >> T;
    while (T--) {
        int n, a, b;
        cin >> n >> a >> b;//a是过题数，b是罚时(自己） 
        int s;
        cin >> s;
        vector<int> pre_err(n, 0);          // 封榜前该题的错误提交次数
        vector<bool> passed(n, false);      // 该题是否已在封榜前通过
        vector<int> pass_pen(n, 0);         // 若通过，该题的罚时
        vector<int> first_pd(n, -1);        // 封榜后该题的第一次提交时间
        for (int i = 0; i < s; ++i) {
            int t;
            string p, v;
            cin >> t >> p >> v;
            int idx = p[0] - 'A';
            if (t < 240) {           
                if (v == "ac") {
                    if (!passed[idx]) {
                        passed[idx] = true;
                        pass_pen[idx] = t + 20 * pre_err[idx];
                    }
                } else if (v == "rj") {
                    if (!passed[idx]) {
                        pre_err[idx]++;
                    }
                }
            } else {                       
                if (!passed[idx] && first_pd[idx] == -1) {
                    first_pd[idx] = t;
                }
            }
        }

        int pre_ac = 0;
        int pre_pen = 0;//封榜前罚时 
        for (int i = 0; i < n; ++i) {
            if (passed[i]) {
                pre_ac++;
                pre_pen += pass_pen[i];
            }
        }
        vector<int> cand;//可能的罚时 
        for (int i = 0; i < n; ++i) {
            if (!passed[i] && first_pd[i] != -1) {
                int pen = first_pd[i] + 20 * pre_err[i];
                cand.push_back(pen);
            }
        }
        sort(cand.begin(), cand.end());
        int m = cand.size();
        vector<int> prefix(m + 1, 0);
        for (int i = 0; i < m; ++i) {
            prefix[i + 1] = prefix[i] + cand[i];
        }
        if (pre_ac > a) {
            cout << 0 << '\n';
            continue;
        }
        int need = a - pre_ac + 1;          // 使通过题数严格大于 a 所需的最小封榜后过题数
        int ans = -1;
        // 尝试通过题数等于 a 的情况（x 从 0 到 need-1）
        for (int x =0; x<= m && x < need; ++x) {
            if (pre_ac + x == a && pre_pen + prefix[x] < b) {
                ans = x;
                break;
            }
        }
        // 若没有找到，尝试通过题数大于 a
        if (ans == -1 && need <= m) {
            ans = need;
        }

        cout << ans << '\n';
    }
    return 0;
}
