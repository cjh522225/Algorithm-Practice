#include<bits/stdc++.h>
using namespace std;
struct Edge{
	int u,v,w;// 边的两个端点和权值
};
vector<Edge>edges;//存储所有边
struct DSU{
	vector<int>fa,rk;//fa：父节点 rk：秩（按秩合并）
	DSU(int n){
		fa.resize(n+1);
		iota(fa.begin(),fa.end(),0);//让每个节点的父节点指向自己
		rk.assign(n+1,0);
	}
	int find(int x){
		return fa[x]==x?x:fa[x]=find(fa[x]);// 查找根节点 + 路径压缩（查找 x 所在集合的根节点，同时进行路径压缩：如果 x 不是根（fa[x] != x），则递归找到根，并将 fa[x] 直接赋值为根，使树更扁平。）
	}
	bool unite(int x,int y){// 合并两个集合，返回是否合并成功（即原本不在同一集合）
		x =find(x);
		y =find(y);
		if(x==y){
			return false;//表示已经是在同一个集合里了
		}
		if(rk[x]<rk[y]){
			swap(x,y);
		}
		fa[y]=x;
		if(rk[x]==rk[y]){
			rk[x]++;
		}
		return true;
	}
};
int main(){
	ios::sync_with_stdio(false);
	cin.tie(nullptr);
	cout.tie(nullptr);
	int n,m;
	cin>>n>>m;
	edges.resize(m);
	for(int i=0;i<m;i++){
		cin>>edges[i].u>>edges[i].v>>edges[i].w;
	}
    // Kruskal算法：按边权从小到大排序
	sort(edges.begin(),edges.end(),[](const Edge&a,const Edge&b){
		return a.w<b.w;
	});
	DSU dsu(n);
	long long ans=0;// 最小生成树总权值（可能很大，用long long）
	int cnt=0;//已选的边的数量
	for(auto&e:edges){
		if(dsu.unite(e.u,e.v)){
			ans+=e.w;
			cnt++;
			if(cnt==n-1)
			{
				break;
			}
		}
	}
	if (cnt == n - 1) cout << ans << '\n';
    else cout << "orz\n";
    return 0;
}
