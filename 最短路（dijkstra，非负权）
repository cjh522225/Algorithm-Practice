#include<bits/stdc++.h>
using namespace std;
struct Edge{
	int u,v,w;
};
vector<Edge>edges;
struct DSU{//并查集 
	vector<int>fa,rk;//fa是父节点，rk是秩（和树高差不多 ） 
	DSU(int n){
		fa.resize(n+1);
		iota(fa.begin(),fa.end(),0);//iota是用来批量递增赋值给fa的 （将fa赋值成0，1，2，3，4.....n） 
		rk.assign(n+1,0);
	}
	int find(int x){
		return fa[x]==x?x:fa[x]=find(fa[x]);//查找根节点并且进行了路径压缩 
	}
	bool unite(int x,int y){//开始按秩合并 
		x =find(x);
		y =find(y);
		if(x==y){
			return false;
		}
		if(rk[x]<rk[y]){
			swap(x,y);
		}
		fa[y]=x;
		if(rk[x]==rk[y]){
			rk[x]++;
		}
		return true;
	}
};
int main(){
	ios::sync_with_stdio(false);
	cin.tie(nullptr);
	cout.tie(nullptr);
	int n,m;
	cin>>n>>m;
	edges.resize(m);
	for(int i=0;i<m;i++){
		cin>>edges[i].u>>edges[i].v>>edges[i].w;//输入顶点，边，权重 
	}
	sort(edges.begin(),edges.end(),[](const Edge&a,const Edge&b){
		return a.w<b.w;//按权重排序 
	});
	DSU dsu(n);
	long long ans=0;//记录已经加上去的权重和 
	int cnt=0;//记录已选入mst的边数 
	for(auto&e:edges){
		if(dsu.unite(e.u,e.v)){//如果按秩合并成功 
			ans+=e.w;//将边权加进总的权重和 
			cnt++;//将边数+1 
			if(cnt==n-1)//如果边数已经达到n-1就说明最小生成树构成了 
			{
				break;
			}
		}
	}
	if (cnt == n - 1) cout << ans << '\n';
    else cout << "orz\n";
    return 0;
}
