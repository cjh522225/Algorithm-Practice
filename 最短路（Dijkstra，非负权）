#include <bits/stdc++.h>
using namespace std;
using ll = long long;

const ll INF = 1e18;   // 足够大的“无穷远”

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);
	cout.tie(nullptr); 
    int n, m, s;//顶点，边，权重
    cin >> n >> m >> s;
    // 邻接表：g[u] 存储 (v, w)
    vector<vector<pair<int, ll>>> g(n + 1);
    for (int i = 0; i < m; ++i) {
        int u, v;
        ll w;
        cin >> u >> v >> w;
        g[u].emplace_back(v, w);   // 有向边//emplace_back是直接在容器最后生成一个数，相比于push_back的先生成在移动到容器末尾最后销毁有效率优势
    }

    // 距离数组，初始为 INF
    vector<ll> dis(n + 1, INF);
    dis[s] = 0;

    // 小根堆： (距离, 顶点)(为了可以直接取出堆顶最小的值）
    using pli = pair<ll, int>;
    priority_queue<pli, vector<pli>, greater<pli>> pq;
    pq.push({0, s});

    while (!pq.empty()) {
        auto [d, u] = pq.top();//取出堆顶元素
        pq.pop();

        // 过时的旧记录直接丢弃
        if (d != dis[u]) continue;

        // 遍历所有邻居
        for (auto [v, w] : g[u]) {
            if (dis[v] > dis[u] + w) {
                dis[v] = dis[u] + w;
                pq.push({dis[v], v});
            }
        }
    }

    // 输出结果（题目保证所有点都可从 s 到达，因此 dis 均被更新）
    for (int i = 1; i <= n; ++i) {
        cout << dis[i] << " \n"[i == n];
    }
    return 0;
}
